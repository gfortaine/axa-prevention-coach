# Mistral managed PDF RAG
MISTRAL_API_KEY=
MISTRAL_LIBRARY_ID=
MISTRAL_AGENT_ID=
MISTRAL_API_BASE_URL=https://api.mistral.ai
MISTRAL_DOCUMENT_METADATA_PATH=services/agent/corpus/mistral_documents.json
MISTRAL_UPLOAD_DELAY_S=1
MISTRAL_UPLOAD_RETRIES=5
MISTRAL_UPLOAD_BACKOFF_S=2
MISTRAL_DOWNLOAD_TIMEOUT_S=30
MISTRAL_CONVERSATION_TIMEOUT_MS=120000

# Web text-to-speech
MISTRAL_TTS_BASE_URL=https://api.mistral.ai/v1
MISTRAL_TTS_MODEL=voxtral-mini-tts-2603
MISTRAL_TTS_VOICE_ID=fr_marie_neutral
MISTRAL_TTS_RESPONSE_FORMAT=mp3
MISTRAL_TTS_CHUNK_MAX_CHARS=1800
